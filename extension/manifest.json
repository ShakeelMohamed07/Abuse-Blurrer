{
  "manifest_version": 3,
  "name": "Toxic Comment Blurrer",
  "version": "1.1",
  "description": "Automatically blurs or hides toxic and abusive comments on YouTube in real time.",

  "permissions": ["activeTab", "scripting", "storage"],

  "host_permissions": [
  "https://www.youtube.com/*",
  "https://*.ngrok-free.dev/*",
  "http://127.0.0.1:5000/*"
],


  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
  {
    "matches": ["https://www.youtube.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  },
  {
    "matches": ["file:///D:/VILASNI/abuse_blurrer/test.html"],
    "js": ["test_content.js"],
    "run_at": "document_idle"
  }
],



  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Toxic Comment Blurrer"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
