{
  "manifest_version": 3,
  "name": "Toxic Comment Blurrer",
  "version": "1.0",
  "description": "Blurs toxic and abusive comments using an ML backend",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://www.youtube.com/*"
  ],

  "background": {
  "service_worker": "background.js"
}
,

  "content_scripts": [
  {
    "matches": ["https://www.youtube.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
]

}
